pipeline {
  agent any

  environment {
    IMAGE = "githumohit/testapp"
    TAG = "latest"
  }

  stages {

    stage('Checkout Code') {
      steps {
echo'pulling website code...'
        git branch: 'main',
            url: 'https://github.com/Githumohit/docker-testapp.git'
      }
    }

    stage('Build Docker Image') {
      steps {
        powershell "docker build -t docker-testapp:latest ."
      }
    }
stage ("Run Container") {
  Steps {
    powershell """
      docker stop docker-testapp 2>\$null
      docker rm docker-testapp 2>\$null
      docker run -d --name docker-testapp -p 9090:80 docker-testapp:latest
    """

  }
}

  post {
    success {
      echo "app running at https://localhost:9090"
    }
  }
}
